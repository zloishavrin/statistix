{
	"compilerOptions": {
		"module": "ESNext",
		"esModuleInterop": true,
		"paths": {
			"@entities/*": ["./src/entities/*"],
			"@features/*": ["./src/features/*"],
			"@pages/*": ["./src/pages/*"],
			"@shared/*": ["./src/shared/*"],
			"@widgets/*": ["./src/widgets/*"],
			"@app/*": ["./src/app/*"]
		},
		"jsx": "react-jsx"
	},
	"include": ["**/*.ts", "**/*.tsx"]
}
